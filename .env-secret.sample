# OpenClaw deployment configuration
#
# Setup:
#   1. Copy this file:  cp .env-secret.sample .env-secret
#   2. Edit the values: vim .env-secret
#   3. Run the script:  sudo bash scripts/setup_headscale.sh
#
# .env-secret is listed in .gitignore and will never be committed.

# ---------------------------------------------------------------------------
# Headscale (scripts/setup_headscale.sh)
# ---------------------------------------------------------------------------

# Public domain name for Headscale — must have a DNS A record pointing to this VPS.
HEADSCALE_DOMAIN="headscale.example.com"

# Email address used for Let's Encrypt certificate registration.
LE_EMAIL="contact@example.com"

# Internal address where Headscale listens (default: 127.0.0.1:8080).
# Only change this if you modified listen_addr in /etc/headscale/config.yaml.
# HEADSCALE_ADDR="127.0.0.1:8080"

# ---------------------------------------------------------------------------
# OpenClaw (scripts/setup_openclaw.sh)
# ---------------------------------------------------------------------------

# API key for the cortecs.ai model provider.
CORTECS_API_KEY="your-cortecs-api-key"

# Telegram bot token for the OpenClaw Telegram channel.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Gateway authentication token — any strong random string.
# Generate one with: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN="your-gateway-token"

# ---------------------------------------------------------------------------
# Secrets deployment (scripts/deploy_secrets.sh)
# ---------------------------------------------------------------------------

# System user that runs the OpenClaw service (default: openclaw).
# OPENCLAW_USER="openclaw"

# Path to the age private key used by SOPS (default: /etc/openclaw/age-key.txt).
# SOPS_AGE_KEY_FILE="/etc/openclaw/age-key.txt"
