# OpenClaw client configuration
#
# Setup:
#   1. Copy this file:  cp .client-secret-env.sample .client-secret-env
#   2. Edit the values: vim .client-secret-env
#   3. Run the script:  bash client/setup_client.sh
#
# .client-secret-env is listed in .gitignore and will never be committed.

# ---------------------------------------------------------------------------
# OpenClaw gateway connection
# ---------------------------------------------------------------------------

# WebSocket URL of the remote OpenClaw gateway (Tailscale IP + port).
# Use ws:// for a WireGuard/Tailscale-encrypted connection (plain HTTP at the
# application layer, but encrypted at the network layer — safe on Tailscale).
# Use wss:// if the gateway is behind a TLS-terminating reverse proxy.
OPENCLAW_GATEWAY_URL="ws://100.64.x.x:18789"

# Authentication token — must match OPENCLAW_GATEWAY_TOKEN set on the VPS.
OPENCLAW_GATEWAY_TOKEN="your-gateway-token"

# ---------------------------------------------------------------------------
# Tailscale network
# ---------------------------------------------------------------------------

# Self-hosted Headscale coordination server URL.
# Leave blank or remove this line to use Tailscale's official coordination servers.
HEADSCALE_URL="https://headscale.example.com"

# Pre-auth key for this device. Generate one on the server with:
#   headscale preauthkeys create --user <user-id> --expiration 1h
# Leave blank or remove this line to skip automatic network join and run
# 'sudo tailscale up' manually.
TAILSCALE_AUTH_KEY="your-preauth-key"

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# Bot token — must match TELEGRAM_BOT_TOKEN set on the VPS.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Chat ID to send messages to (your personal chat or a group).
# To find your chat ID:
#   1. Start a conversation with your bot in Telegram.
#   2. Run: curl https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Look for the 'id' field inside 'chat' in the response.
TELEGRAM_CHAT_ID="your-chat-id"
